{
	"rewrites": [
		{
			"source": "/blog/:path*",
			"destination": "https://blog-tan-sigma-87.vercel.app/:path*"
		},
		{
			"source": "/blog",
			"destination": "https://blog-tan-sigma-87.vercel.app/"
		},
		{
			"source": "/_next/:path*",
			"destination": "https://dailyrow.vercel.app/_next/:path*"
		},
		{
			"source": "/row/:path*",
			"destination": "https://dailyrow.vercel.app/:path*"
		},
		{
			"source": "/row",
			"destination": "https://dailyrow.vercel.app/"
		}
	]
}
